{
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Edit(*.ts)",
      "Bash(cd*)",
      "Edit(*.tsx)",
      "Edit(*.json)",
      "Bash(docker*)",
      "Write(*.sh)",
      "Write(*.bat)",
      "Edit(*.yml)",
      "Write(*.md)",
      "Write(*.ts)",
      "Edit(*.css)",
      "Bash(ls*)",
      "Bash(ssh*)",
      "Bash(curl*)"
    ],
    "deny": []
  },
  "mcpServers": {
    "reddit": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "git+https://github.com/adhikasp/mcp-reddit.git", "mcp-reddit"]
    }
  }
}