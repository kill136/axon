{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "echo 'Skip install for landing page'",
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": "landing-page",
  "framework": null,
  "functions": {
    "api/download.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/download/:filename",
      "destination": "/api/download?file=:filename"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/style.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true
}
